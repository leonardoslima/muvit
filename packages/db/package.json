{
  "name": "@muvit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "generate": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs generate",
    "migrate": "node --env-file=.env --import tsx src/migrate.ts",
    "migrate:test": "node --env-file=.env.test --import tsx src/ensure-database.ts && node --env-file=.env.test --import tsx src/migrate.ts",
    "studio": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs studio",
    "seed": "node --env-file=.env --import tsx src/seed.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@muvit/config": "workspace:*",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
